# =============================================================================
# PI REMOVER - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
#
# This file documents ALL available environment variables for PI Remover.
#
# SETUP INSTRUCTIONS:
# -------------------
# 1. For DEVELOPMENT:
#    - Use docker/.env.dev (already configured with test credentials)
#    - Safe to use as-is for local development
#
# 2. For PRODUCTION:
#    - Copy docker/.env.prod.template to docker/.env.prod
#    - Generate strong secrets for all REPLACE_WITH_* values
#    - NEVER commit .env.prod to version control
#
# SECRET GENERATION:
# ------------------
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# =============================================================================


# =============================================================================
# SECTION 1: ENVIRONMENT IDENTIFICATION
# =============================================================================

# Environment name (dev, staging, prod)
# Affects logging level, debug endpoints, rate limits
ENVIRONMENT=dev

# Application version (for logging/debugging)
VERSION=2.5.0


# =============================================================================
# SECTION 2: JWT AUTHENTICATION
# =============================================================================

# JWT Secret Key (REQUIRED)
# - Minimum 32 characters for security
# - Must be kept secret and unique per environment
# - Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# DEV (generate your own):
JWT_SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
#
# PROD (generate your own - NEVER commit real secrets):
# JWT_SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS

# JWT Token Expiry (in minutes)
# DEV: longer expiry for convenience
# PROD: shorter expiry for security
JWT_EXPIRY_MINUTES=1440   # DEV: 24 hours
# JWT_EXPIRY_MINUTES=60   # PROD: 1 hour


# =============================================================================
# SECTION 3: API CLIENT CREDENTIALS
# =============================================================================

# DEV Credentials (safe to use as-is for development)
DEV_CLIENT_ID=pi-dev-client
DEV_CLIENT_SECRET=REPLACE_WITH_GENERATED_SECRET

# PROD Credentials (generate your own for production)
PROD_CLIENT_ID=pi-prod-client
PROD_CLIENT_SECRET=REPLACE_WITH_GENERATED_SECRET
# For production, generate new secret:
# PROD_CLIENT_SECRET=REPLACE_WITH_STRONG_SECRET_32_CHARS_MIN


# =============================================================================
# SECTION 4: RATE LIMITING
# =============================================================================

# Requests per minute per client
# DEV: lower for development
# PROD: higher for real workloads
RATE_LIMIT_REQUESTS=100     # DEV
# RATE_LIMIT_REQUESTS=1000  # PROD

# Rate limit window (in seconds)
RATE_LIMIT_WINDOW=60


# =============================================================================
# SECTION 5: PROCESSING LIMITS
# =============================================================================

# Maximum text length (characters) for single request
MAX_TEXT_LENGTH=50000

# Maximum batch size for /v1/redact/batch endpoint
MAX_BATCH_SIZE=100

# Request timeout (seconds)
REQUEST_TIMEOUT=60


# =============================================================================
# SECTION 6: LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO        # DEV
# LOG_LEVEL=WARNING   # PROD (recommended for less noise)

# Log format: text, json
# Use 'json' for log aggregators (ELK, Splunk, etc.)
LOG_FORMAT=text       # DEV
# LOG_FORMAT=json     # PROD (recommended for aggregation)


# =============================================================================
# SECTION 7: PI DETECTION SETTINGS
# =============================================================================

# Enable Named Entity Recognition (spaCy)
# - true: Better accuracy, higher memory (~500MB), slower
# - false: Faster, regex + dictionary only
ENABLE_NER=true

# NER model to use (if ENABLE_NER=true)
# Options: en_core_web_sm (small), en_core_web_md (medium), en_core_web_lg (large)
NER_MODEL=en_core_web_sm


# =============================================================================
# SECTION 8: CORS CONFIGURATION
# =============================================================================

# Allowed origins for CORS (comma-separated)
# DEV: Allow local development origins
CORS_ORIGINS=http://localhost:8082,http://localhost:9082,http://127.0.0.1:8082

# PROD: Restrict to specific domains
# CORS_ORIGINS=https://your-app.your-domain.com


# =============================================================================
# SECTION 9: NETWORK CONFIGURATION
# =============================================================================

# Host to bind to (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Ports (usually set in docker-compose.yml, not here)
# API_PORT=8080   # DEV
# API_PORT=9080   # PROD
# WEB_PORT=8082   # DEV
# WEB_PORT=9082   # PROD


# =============================================================================
# SECTION 10: DEBUG SETTINGS (DEV ONLY)
# =============================================================================

# Enable debug mode (NEVER enable in production!)
DEBUG=true          # DEV only
# DEBUG=false       # PROD (always false)

# Enable Swagger UI documentation
ENABLE_SWAGGER=true   # DEV
# ENABLE_SWAGGER=false # PROD (recommended for security)


# =============================================================================
# SECTION 11: EXTERNAL SERVICES (OPTIONAL)
# =============================================================================

# Redis (for distributed rate limiting or caching)
# REDIS_URL=redis://localhost:6379/0

# Database (if using persistent storage)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pi_remover
# DB_USER=pi_remover_user
# DB_PASSWORD=REPLACE_WITH_DB_PASSWORD


# =============================================================================
# SECTION 12: GCP SETTINGS (FOR CLOUD RUN DEPLOYMENT)
# =============================================================================

# GCP Project ID
# GCP_PROJECT_ID=your-project-id

# GCP Region
# GCP_REGION=us-central1

# Artifact Registry path
# ARTIFACT_REGISTRY=us-central1-docker.pkg.dev/your-project-id/pi-remover


# =============================================================================
# QUICK REFERENCE
# =============================================================================
#
# DEVELOPMENT (docker/.env.dev):
# ------------------------------
#   ENVIRONMENT=dev
#   JWT_SECRET_KEY=YOUR_DEV_JWT_SECRET_HERE
#   DEV_CLIENT_ID=pi-dev-client
#   DEV_CLIENT_SECRET=REPLACE_WITH_GENERATED_SECRET
#   RATE_LIMIT_REQUESTS=100
#   ENABLE_SWAGGER=true
#   DEBUG=true
#
# PRODUCTION (docker/.env.prod):
# ------------------------------
#   ENVIRONMENT=prod
#   JWT_SECRET_KEY=<generate-32-char-secret>
#   PROD_CLIENT_ID=pi-prod-client
#   PROD_CLIENT_SECRET=<generate-32-char-secret>
#   RATE_LIMIT_REQUESTS=1000
#   ENABLE_SWAGGER=false
#   DEBUG=false
#   LOG_FORMAT=json
#
# =============================================================================
