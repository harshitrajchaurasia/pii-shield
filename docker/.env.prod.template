# PI Remover - PRODUCTION Environment Variables
# ===============================================
# ⚠️  IMPORTANT SECURITY NOTICE:
#     1. Copy this file to .env.prod
#     2. Generate strong, unique secrets for ALL values
#     3. NEVER commit .env.prod to version control
#     4. Store secrets in a secure secrets manager in production
#
# This file is a TEMPLATE. The real .env.prod should be in .gitignore!

# =========================================================================
# JWT Configuration (REQUIRED)
# =========================================================================
# Generate a strong 256-bit secret:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
PROD_JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS

# =========================================================================
# Authentication Clients (REQUIRED)
# =========================================================================
# Format: client_id:client_secret:description,client_id2:secret2:desc2
# Secret must be at least 32 characters!
# Generate secrets:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
PROD_AUTH_CLIENTS=prod-client:REPLACE_WITH_STRONG_SECRET_32_CHARS_MIN:production-service

# =========================================================================
# CORS Configuration
# =========================================================================
# Comma-separated list of allowed origins
PROD_CORS_ORIGINS=https://your-app.your-domain.com

# =========================================================================
# Version
# =========================================================================
VERSION=1.0.0

# =========================================================================
# Database (if using persistent storage)
# =========================================================================
# DB_HOST=your-db-host
# DB_PORT=5432
# DB_NAME=pi_remover
# DB_USER=pi_remover_user
# DB_PASSWORD=REPLACE_WITH_DB_PASSWORD

# =========================================================================
# External Services (if applicable)
# =========================================================================
# REDIS_URL=redis://your-redis-host:6379/0
# SENTRY_DSN=https://your-sentry-dsn

# =========================================================================
# SSL/TLS (if terminating SSL at container level)
# =========================================================================
# SSL_CERT_PATH=/etc/ssl/certs/your-cert.pem
# SSL_KEY_PATH=/etc/ssl/private/your-key.pem
